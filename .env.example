# ══════════════════════════════════════════════════════════
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - ORION 360
# ══════════════════════════════════════════════════════════
# Copia este archivo a .env y completa los valores

# Seguridad
SECRET_KEY=tu_clave_secreta_aqui

# Base de datos (PostgreSQL de Neon)
DATABASE_URL=postgresql://neondb_owner:TU_PASSWORD@ep-tu-proyecto.neon.tech/neondb?sslmode=require

# APIs de Inteligencia Artificial
GROQ_API_KEY=gsk_tu_clave_groq_aqui
GEMINI_API_KEY=tu_clave_gemini_aqui

# Google OAuth
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/login/google

# Cloudinary (imágenes)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# OpenWeather (clima)
OPENWEATHER_API_KEY=tu_api_key_de_openweather

# Wompi (pagos)
WOMPI_PUBLIC_KEY=tu_public_key
WOMPI_PRIVATE_KEY=tu_private_key
WOMPI_INTEGRITY_KEY=tu_integrity_key

# Correo (Brevo)
MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=tu_correo@ejemplo.com
MAIL_PASSWORD=tu_password_de_correo
MAIL_DEFAULT_SENDER=Oryon 360 <tu_correo@ejemplo.com>

# Servidor
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=True